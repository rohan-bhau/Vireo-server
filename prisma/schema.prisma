generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Workspace {
  id          String            @id @default(uuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  members     WorkspaceMember[]
  invitations Invitation[]
  projects    Project[]

  @@map("workspaces")
}

model WorkspaceMember {
  id         String        @id @default(uuid())
  workspaceId String
  userId     String
  role       WorkspaceRole @default(MEMBER)
  joinedAt   DateTime      @default(now())
  invitedBy  String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Invitation {
  id           String            @id @default(uuid())
  workspaceId  String
  inviterId    String
  inviteeEmail String
  role         WorkspaceRole     @default(MEMBER)
  message      String?
  token        String            @unique
  status       InvitationStatus  @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime          @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  key         String
  workspaceId String
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boards    Board[]
  sprints   Sprint[]

  @@unique([workspaceId, key])
  @@map("projects")
}

model Board {
  id        String   @id @default(uuid())
  name      String
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns Column[]

  @@map("boards")
}

model Column {
  id        String   @id @default(uuid())
  name      String
  position  Int
  boardId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, position])
  @@map("columns")
}

model Sprint {
  id        String        @id @default(uuid())
  name      String
  goal      String?
  projectId String
  status    SprintStatus  @default(PLANNING)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("sprints")
}
